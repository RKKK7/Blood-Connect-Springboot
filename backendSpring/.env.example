# Copy these into your shell environment before running the backend
# (e.g. `export DB_URL=...`) OR edit the defaults directly in
# src/main/resources/application.properties

# ---- PostgreSQL ----
DB_URL=jdbc:postgresql://localhost:5432/bloodconnect
DB_USER=postgres
DB_PASSWORD=postgres

# ---- HTTP (REST API) port ----  (Vite proxies /api here)
PORT=8080

# ---- Socket.IO port ----        (real-time chat / live feed)
SOCKET_PORT=5000

# ---- Redis cache ----  (Docker sets REDIS_HOST=redis automatically)
REDIS_HOST=localhost
REDIS_PORT=6379
# Set CACHE_TYPE=none to run locally without a Redis server.
CACHE_TYPE=redis

# ---- Security ----
JWT_SECRET=please_change_me_to_a_long_random_string_at_least_32_chars
ADMIN_SECRET=bloodconnect_admin_2024

# ---- Frontend origin (CORS + email links + socket origin) ----
CLIENT_URL=http://localhost:5173

# ---- Groq AI (https://console.groq.com/keys). Optional: blank = safe fallbacks ----
GROQ_API_KEY=

# ---- Gmail SMTP (optional: blank = emails are logged, not sent) ----
EMAIL_USER=
EMAIL_PASS=
